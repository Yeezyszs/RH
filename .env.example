# Credenciais Supabase — copie este arquivo para .env e preencha
# O .env NÃO deve ser commitado (está no .gitignore)

# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon/public (segura para usar no frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NUNCA inclua a service_role key aqui ou em qualquer arquivo frontend
# SUPABASE_SERVICE_KEY=  ← PROIBIDO no frontend
